{
  "compilerOptions": {
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "allowImportingTsExtensions": true,
    "jsx": "react-jsx",
    "paths": {
      "@/*": ["./apps/web/*"]
    },
    "target": "ES2017"
  },
  "include": [
    "packages/**/*.ts",
    "tests/**/*.ts",
    "apps/agent-host/**/*.ts",
    "apps/web/**/*.ts",
    "apps/web/**/*.tsx",
    "playwright.config.ts",
    "vitest.config.ts"
  ],
  "exclude": ["node_modules", "apps/web/.next"]
}
