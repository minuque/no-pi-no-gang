{
  "name": "@minuque/no-pi-no-gang",
  "version": "0.0.7",
  "description": "Web UI for the pi coding agent",
  "license": "MIT",
  "bin": {
    "no-pi-no-gang": "bin/no-pi-no-gang.js"
  },
  "files": [
    "bin",
    ".next",
    "!.next/cache",
    "!.next/dev",
    "!.next/**/*.js.map",
    "public",
    "next.config.ts",
    "package.json"
  ],
  "scripts": {
    "dev": "next dev --webpack -p 7777 --hostname 127.0.0.1",
    "dev:turbo": "next dev --turbopack -p 7777 --hostname 127.0.0.1",
    "dev:debug": "next dev --webpack -p 7777 --hostname 127.0.0.1 --inspect",
    "build": "next build --turbopack",
    "postbuild": "node scripts/generate-external-modules-manifest.js",
    "start": "next start -p 7788",
    "start:test": "next start -p 30142 --hostname 127.0.0.1",
    "test": "vitest run",
    "playwright:install": "playwright install chromium",
    "test:e2e": "playwright test",
    "pack:smoke": "node scripts/pack-smoke.js",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint . --max-warnings=0",
    "lint:design": "node node_modules/@google/design.md/dist/index.js lint DESIGN.md",
    "verify:fast": "npm run typecheck && npm run lint && npm run test",
    "verify": "npm run format:check && npm run lint:design && npm run verify:fast && npm run build",
    "verify:release": "npm run verify && npm run playwright:install && npm run test:e2e && npm run pack:smoke",
    "release": "npm run verify:release && npm version patch --no-git-tag-version && npm run build && npm publish --access public",
    "prepare": "husky"
  },
  "dependencies": {
    "@earendil-works/pi-ai": "^0.78.0",
    "@earendil-works/pi-coding-agent": "^0.78.0",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@lobehub/icons": "^5.6.0",
    "@types/react-syntax-highlighter": "^15.5.13",
    "mammoth": "^1.12.0",
    "mermaid": "^11.14.0",
    "next": "16.2.1",
    "next-intl": "^4.13.0",
    "nprogress": "^0.2.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.1.1",
    "remark-gfm": "^4.0.1",
    "sonner": "^2.0.7"
  },
  "devDependencies": {
    "@google/design.md": "^0.3.0",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4.2.2",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/node": "^25",
    "@types/nprogress": "^0.2.3",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "agentation": "^3.0.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "postcss": "^8",
    "prettier": "^3.8.4",
    "tailwindcss": "^4.3.2",
    "typescript": "5.9.3",
    "vitest": "^4.1.9"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs,cjs}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,css,html,yaml,yml}": [
      "prettier --write"
    ],
    "DESIGN.md": [
      "node node_modules/@google/design.md/dist/index.js lint"
    ]
  }
}
